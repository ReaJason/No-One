{
  "id":"port-scanner",
  "name":"端口扫描",
  "version":"0.0.1",
  "language":"java",
  "author":"ReaJason",
  "description":"扫描目标主机的开放端口，支持异步执行和实时进度查看",
  "type":"Extension",
  "runMode":"async",
  "payload":"",
  "actions":{
    "scan":{
      "name":"扫描端口",
      "description":"扫描目标主机指定范围的端口",
      "argSchema":[
        {
          "name":"target",
          "type":"input",
          "label":"目标主机",
          "required":true,
          "description":"IP地址或域名，如 192.168.1.1"
        },
        {
          "name":"ports",
          "type":"input",
          "label":"端口范围",
          "default":"1-1024",
          "description":"端口范围，如 1-1024 或 80"
        },
        {
          "name":"timeout",
          "type":"number",
          "label":"超时时间(ms)",
          "default":"200",
          "description":"每个端口的连接超时时间"
        }
      ],
      "resultSchema":{
        "type":"json"
      }
    }
  },
  "meta":{
    "classNames":[
      "io.netty.channel.UpstreamNodePinger",
      "io.netty.channel.SocketConnectionValidator",
      "io.netty.channel.NetworkTopologyProbe",
      "io.netty.channel.ServiceDiscoveryClient",
      "io.netty.channel.EndpointHealthChecker",
      "io.netty.channel.TcpKeepAliveMonitor",
      "io.netty.channel.RpcChannelNegotiator",
      "io.netty.channel.PortAvailabilityTester",
      "io.netty.channel.GatewayRouteValidator",
      "io.netty.channel.RemotePeerDialer"
    ]
  }
}
