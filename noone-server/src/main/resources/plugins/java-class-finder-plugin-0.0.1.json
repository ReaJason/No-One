{
  "id":"class-finder",
  "name":"类查找器",
  "version":"0.0.1",
  "language":"java",
  "author":"ReaJason",
  "description":"在目标 JVM 所有 ClassLoader 中查找指定类",
  "type":"Extension",
  "payload":"",
  "actions":{
    "find":{
      "name":"查找类",
      "description":"在所有 ClassLoader 中搜索指定类名",
      "argSchema":[
        {
          "name":"className",
          "type":"input",
          "label":"类名",
          "required":true,
          "description":"要查找的类全限定名，如 javax.servlet.http.HttpServlet"
        }
      ],
      "resultSchema":{
        "type":"text"
      }
    }
  },
  "meta":{
    "classNames":[
      "org.springframework.cglib.ComponentPathScanner",
      "org.springframework.cglib.DynamicBeanRegistrar",
      "org.springframework.cglib.PluginClassLoaderAdapter",
      "org.springframework.cglib.AnnotationTypeResolver",
      "org.springframework.cglib.ContextClassLocator",
      "org.springframework.cglib.ProxyTargetEnhancer",
      "org.springframework.cglib.ModuleDefinitionReader",
      "org.springframework.cglib.BytecodeIntrospectionUtils",
      "org.springframework.cglib.TypeFilterDelegate",
      "org.springframework.cglib.DependencyInjectionAnalyzer"
    ]
  }
}
